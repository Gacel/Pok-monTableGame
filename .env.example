# .env.example — SOLO variables NO sensibles o punteros a Vault.
# Copia a `.env` (git-ignored). Las credenciales REALES van a HashiCorp Vault (C1.1),
# nunca aquí.

# --- General ---
NODE_ENV=development
LOG_LEVEL=info
TZ=Europe/Madrid

# --- Gateway (C0.3) ---
GATEWAY_HTTPS_PORT=443

# --- Vault (C1.1) — token raíz SOLO para modo dev local ---
# (no es un secreto real de producción; Vault dev lo regenera en cada arranque
#  salvo que se fije este token de desarrollo)
VAULT_ADDR=http://vault:8200
VAULT_DEV_ROOT_TOKEN=dev-only-root-token

# --- Infra (se activan en Fase 2/3) ---
RABBITMQ_URL=amqp://rabbitmq:5672
REDIS_URL=redis://redis:6379

# --- Punteros a secretos en Vault (las claves se leen en runtime) ---
# JWT_SECRET_PATH=secret/transcendence/jwt
# GOOGLE_OAUTH_PATH=secret/transcendence/google_oauth
# SMTP_PATH=secret/transcendence/smtp

# --- Credenciales temporales para Dev Local (hasta usar Vault) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

FRONTEND_URL=https://poke.42transcendence.com

# --- JWT de sesión ---
# Secreto para firmar los JWT (mín. 16 caracteres). El arranque ABORTA si falta.
# SOLO dev: en producción va a Vault (C1.1), nunca un secreto real aquí.
# Cámbialo por un valor largo y aleatorio.
JWT_SECRET=dev-only-insecure-secret-change-me

# --- Cookie de sesión ---
# La sesión viaja en una cookie HttpOnly. `Secure` se activa por defecto (HTTPS).
# Ponlo a false SOLO si accedes por http directo sin gateway (p.ej. localhost:5173).
COOKIE_SECURE=true

# --- Login de PRUEBAS (⚠️ PUERTA TRASERA) ---
# Con true, permite entrar con admin@42transcendence.com / 42transcendence SIN
# registro (la cuenta se crea al primer login). SOLO testeo; DESACTIVAR en prod.
ALLOW_TEST_LOGIN=false
